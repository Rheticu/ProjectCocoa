[gd_scene load_steps=2 format=3 uid="uid://dd31xj3j5hlkc"]

[sub_resource type="GDScript" id="GDScript_3s6pn"]
script/source = "extends CanvasLayer

@export var map_size := Vector2i(20, 11)
@onready var fog_texture = $FogTexture

# Track exploration state
var explored_cells := {}
var currently_visible_cells := {}  # Renamed from visible_cells

func initialize_fog():
	var fog_image = Image.create(map_size.x, map_size.y, false, Image.FORMAT_RGBA8)
	fog_image.fill(Color(0, 0, 0, 1))  # Start with full fog
	fog_texture.texture = ImageTexture.create_from_image(fog_image)
	fog_texture.stretch_mode = TextureRect.STRETCH_TILE
	fog_texture.size = Vector2(map_size * 32)

func update_fog(units: Array):
	var fog_image = fog_texture.texture.get_image()
	var new_visible := {}
	
	# Mark all previously visible cells as explored
	for cell in currently_visible_cells:
		explored_cells[cell] = true
	
	# Calculate new visibility
	for unit in units:
		for cell in unit.get_vision_cells():
			# Convert to image coordinates (flip y-axis)
			var img_x = cell.x
			var img_y = map_size.y - 1 - cell.y  # Flip y-coordinate
			
			if img_x >= 0 and img_x < map_size.x and img_y >= 0 and img_y < map_size.y:
				new_visible[cell] = true
				fog_image.set_pixel(img_x, img_y, Color.TRANSPARENT)
	
	# Apply fog for explored but not visible areas
	for cell in explored_cells:
		if not new_visible.has(cell):
			var img_x = cell.x
			var img_y = map_size.y - 1 - cell.y
			fog_image.set_pixel(img_x, img_y, Color(0, 0, 0, 0.3))
	
	currently_visible_cells = new_visible
	fog_texture.texture.update(fog_image)

# Renamed from is_visible() to avoid conflict with CanvasLayer
func is_cell_visible(cell: Vector2i) -> bool:
	return currently_visible_cells.has(cell)
"

